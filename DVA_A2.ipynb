        "from sklearn.decomposition import PCA\n",
        "import plotly.express as px\n",
        "import numpy as np\n",
        "\n",
        "# Perform PCA for 2D and 3D visualization\n",
        "pca_2d = PCA(n_components=2, random_state=42)\n",
        "pca_3d = PCA(n_components=3, random_state=42)\n",
        "\n",
        "# We use the TF-IDF matrix from earlier (X_tfidf)\n",
        "# Using a subset of 5000 samples for better visualization performance\n",
        "subset_size = 5000\n",
        "X_subset = X_tfidf[:subset_size].toarray()\n",
        "y_subset = df['language'][:subset_size]\n",
        "\n",
        "pca_2d_results = pca_2d.fit_transform(X_subset)\n",
        "pca_3d_results = pca_3d.fit_transform(X_subset)\n",
        "\n",
        "print(f\"PCA 2D Explained Variance: {pca_2d.explained_variance_ratio_.sum():.2%}\")\n",
        "print(f\"PCA 3D Explained Variance: {pca_3d.explained_variance_ratio_.sum():.2%}\")\n",
        "\n",
        "# 2D Plot\n",
        "fig_2d = px.scatter(\n",
        "    x=pca_2d_results[:, 0], y=pca_2d_results[:, 1],\n",
        "    color=y_subset, title=\"PCA 2D Projection of Multilingual Captions\",\n",
        "    labels={'x': 'PC1', 'y': 'PC2'}\n",
        ")\n",
        "fig_2d.show()\n",
        "\n",
        "# 3D Plot\n",
        "fig_3d = px.scatter_3d(\n",
        "    x=pca_3d_results[:, 0], y=pca_3d_results[:, 1], z=pca_3d_results[:, 2],\n",
        "    color=y_subset, title=\"PCA 3D Projection of Multilingual Captions\",\n",
        "    labels={'x': 'PC1', 'y': 'PC2', 'z': 'PC3'}\n",
