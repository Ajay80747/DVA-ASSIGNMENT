        "print(\"Top 10 Words:\")\n",
        "for word, count in word_freq.most_common(10):\n",
        "    print(f\"{word}: {count}\")\n",
        "\n",
        "all_hashtags = [ht for ht in df['hashtags'].str.split().sum()]\n",
        "ht_freq = Counter(all_hashtags)\n",
        "\n",
        "print(\"\\nTop 5 Hashtags:\")\n",
        "for ht, count in ht_freq.most_common(5):\n",
