        "import seaborn as sns\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "st.set_page_config(page_title=\"Social Media Dashboard\", layout=\"wide\")\n",
        "\n",
        "# -------------------------------\n",
        "# LOAD DATA\n",
        "# -------------------------------\n",
        "@st.cache_data\n",
        "def load_data():\n",
        "    df_list = []\n",
        "    with open(\"instagram_data.jsonl\", \"r\", encoding=\"utf-8\") as f:\n",
        "        for line in f:\n",
        "            d = json.loads(line)\n",
        "            lang = d['interaction_data']['hashtags'][0].capitalize()\n",
        "            df_list.append({\n",
        "                'username': d['user_profile']['username'],\n",
        "                'caption': d['content_data']['caption'],\n",
        "                'language': lang,\n",
        "                'likes': d['interaction_data']['likes'],\n",
        "                'comments': d['interaction_data']['comments'],\n",
        "                'shares': d['interaction_data']['shares'],\n",
        "                'followers': len(d['network_data']['followers'])\n",
        "            })\n",
        "    return pd.DataFrame(df_list)\n",
        "\n",
        "df = load_data()\n",
        "\n",
        "# Engagement score\n",
        "df['engagement'] = df['likes'] + df['comments']*2 + df['shares']*3\n",
        "\n",
        "# -------------------------------\n",
        "# SIDEBAR FILTERS\n",
        "# -------------------------------\n",
        "st.sidebar.title(\"Filters\")\n",
        "\n",
        "selected_lang = st.sidebar.multiselect(\n",
        "    \"Select Language\",\n",
        "    options=df['language'].unique(),\n",
        "    default=df['language'].unique()\n",
        ")\n",
        "\n",
        "filtered_df = df[df['language'].isin(selected_lang)]\n",
        "\n",
        "# -------------------------------\n",
        "# HEADER\n",
        "# -------------------------------\n",
        "st.title(\"📊 Instagram Social Media Analysis Dashboard\")\n",
        "\n",
        "# -------------------------------\n",
        "# KPI METRICS\n",
        "# -------------------------------\n",
        "col1, col2, col3, col4 = st.columns(4)\n",
        "\n",
        "col1.metric(\"Total Posts\", len(filtered_df))\n",
        "col2.metric(\"Avg Likes\", int(filtered_df['likes'].mean()))\n",
        "col3.metric(\"Avg Comments\", int(filtered_df['comments'].mean()))\n",
        "col4.metric(\"Avg Engagement\", int(filtered_df['engagement'].mean()))\n",
        "\n",
        "# -------------------------------\n",
        "# CHARTS\n",
        "# -------------------------------\n",
        "\n",
        "# Language Distribution\n",
        "st.subheader(\"🌍 Language Distribution\")\n",
        "fig1 = px.histogram(filtered_df, x='language', color='language')\n",
        "st.plotly_chart(fig1, use_container_width=True)\n",
        "\n",
        "# Engagement Scatter\n",
        "st.subheader(\"🔥 Likes vs Comments\")\n",
        "fig2 = px.scatter(\n",
        "    filtered_df.sample(2000),\n",
        "    x='likes',\n",
        "    y='comments',\n",
        "    color='language',\n",
        "    hover_data=['username']\n",
        ")\n",
        "st.plotly_chart(fig2, use_container_width=True)\n",
        "\n",
        "# Boxplot\n",
        "st.subheader(\"📦 Engagement Distribution\")\n",
        "fig3 = px.box(filtered_df, x='language', y='engagement')\n",
        "st.plotly_chart(fig3, use_container_width=True)\n",
        "\n",
        "# Heatmap (Matplotlib)\n",
        "st.subheader(\"📊 Correlation Heatmap\")\n",
        "corr = filtered_df[['likes','comments','shares','followers']].corr()\n",
        "\n",
        "fig, ax = plt.subplots()\n",
        "sns.heatmap(corr, annot=True, ax=ax)\n",
        "st.pyplot(fig)\n",
        "\n",
        "# -------------------------------\n",
        "# TOP USERS\n",
        "# -------------------------------\n",
        "st.subheader(\"🏆 Top Influential Users\")\n",
        "\n",
        "top_users = filtered_df.sort_values(by='engagement', ascending=False).head(10)\n",
        "st.dataframe(top_users[['username','engagement','likes','comments']])\n",
        "\n",
        "# -------------------------------\n",
        "# RAW DATA\n",
        "# -------------------------------\n",
        "st.subheader(\"📄 Raw Data Sample\")\n",
        "st.dataframe(filtered_df.head(100))"
      ],
