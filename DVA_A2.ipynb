      "cell_type": "code",
      "source": [
        "%%writefile app.py\n",
        "import streamlit as st\n",
        "import pandas as pd\n",
        "import json\n",
        "import plotly.express as px\n",
        "import seaborn as sns\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "st.set_page_config(page_title=\"Instagram Dashboard\", layout=\"wide\")\n",
        "\n",
        "@st.cache_data\n",
        "def load_data():\n",
        "    df_list = []\n",
        "    with open(\"instagram_data.jsonl\", \"r\", encoding=\"utf-8\") as f:\n",
        "        for line in f:\n",
        "            d = json.loads(line)\n",
        "            lang = d['interaction_data']['hashtags'][0].capitalize()\n",
        "            df_list.append({\n",
        "                'username': d['user_profile']['username'],\n",
        "                'caption': d['content_data']['caption'],\n",
        "                'language': lang,\n",
        "                'likes': d['interaction_data']['likes'],\n",
        "                'comments': d['interaction_data']['comments'],\n",
        "                'shares': d['interaction_data']['shares'],\n",
        "                'followers': len(d['network_data']['followers'])\n",
        "            })\n",
        "    return pd.DataFrame(df_list)\n",
        "\n",
        "df = load_data()\n",
        "df['engagement'] = df['likes'] + df['comments']*2 + df['shares']*3\n",
        "\n",
        "# Sidebar\n",
        "st.sidebar.title(\"Filters\")\n",
        "langs = st.sidebar.multiselect(\"Language\", df['language'].unique(), default=df['language'].unique())\n",
        "df = df[df['language'].isin(langs)]\n",
        "\n",
        "# Title\n",
        "st.title(\"📊 Instagram Social Media Analysis Dashboard\")\n",
        "\n",
        "# KPIs\n",
        "c1, c2, c3, c4 = st.columns(4)\n",
        "c1.metric(\"Posts\", len(df))\n",
        "c2.metric(\"Avg Likes\", int(df['likes'].mean()))\n",
        "c3.metric(\"Avg Comments\", int(df['comments'].mean()))\n",
        "c4.metric(\"Engagement\", int(df['engagement'].mean()))\n",
        "\n",
        "# Charts\n",
        "st.subheader(\"Language Distribution\")\n",
        "st.plotly_chart(px.histogram(df, x='language', color='language'), width='stretch')\n",
        "\n",
        "st.subheader(\"Likes vs Comments\")\n",
        "st.plotly_chart(px.scatter(df.sample(2000), x='likes', y='comments', color='language'), width='stretch')\n",
        "\n",
        "st.subheader(\"Engagement by Language\")\n",
        "st.plotly_chart(px.box(df, x='language', y='engagement'), width='stretch')\n",
        "\n",
        "# Heatmap\n",
        "st.subheader(\"Correlation Heatmap\")\n",
        "corr = df[['likes','comments','shares','followers']].corr()\n",
        "fig, ax = plt.subplots()\n",
        "sns.heatmap(corr, annot=True, ax=ax)\n",
        "st.pyplot(fig)\n",
        "\n",
        "# Top users\n",
        "st.subheader(\"Top Influencers\")\n",
        "st.dataframe(df.sort_values(by='engagement', ascending=False).head(10))"
      ],
