      "source": [
        "from transformers import AutoTokenizer, AutoModelForSequenceClassification\n",
        "import torch\n",
        "\n",
        "device = \"cuda\" if torch.cuda.is_available() else \"cpu\"\n",
        "model_name = \"bert-base-multilingual-cased\"\n",
        "\n",
        "print(f\"Loading {model_name} on {device}...\")\n",
        "tokenizer = AutoTokenizer.from_pretrained(model_name)\n",
        "# Since we are just demonstrating, we load a sequence classifier\n",
        "model = AutoModelForSequenceClassification.from_pretrained(model_name, num_labels=3).to(device)\n",
        "\n",
        "def predict_sentiment(text):\n",
        "    inputs = tokenizer(text, return_tensors=\"pt\", truncation=True, padding=True, max_length=128).to(device)\n",
        "    with torch.no_grad():\n",
        "        outputs = model(**inputs)\n",
        "    logits = outputs.logits\n",
        "    predicted_class = torch.argmax(logits, dim=1).item()\n",
        "    mapping = {0: \"Negative\", 1: \"Neutral\", 2: \"Positive\"}\n",
        "    return mapping.get(predicted_class, \"Neutral\")\n",
        "\n",
        "# Run inference on a small sample of 10 for demonstration to save time\n",
        "sample_texts = df['cleaned_caption'].head(10).tolist()\n",
        "predictions = [predict_sentiment(t) for t in sample_texts]\n",
        "\n",
        "for txt, pred in zip(sample_texts[:5], predictions[:5]):\n",
        "    print(f\"Text: {txt}\\nPrediction: {pred}\\n---\")\n"
      ]
    },
