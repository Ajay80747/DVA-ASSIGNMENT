        "# Centrality Measures\n",
        "\n",
        "import networkx as nx\n",
        "\n",
        "# Degree Centrality\n",
        "deg_cent = nx.degree_centrality(G)\n",
        "\n",
        "# Betweenness Centrality\n",
        "bet_cent = nx.betweenness_centrality(G)\n",
        "\n",
        "# Add to DataFrame\n",
        "centrality_df = pd.DataFrame({\n",
        "    'user': list(deg_cent.keys()),\n",
        "    'degree_centrality': list(deg_cent.values()),\n",
        "    'betweenness_centrality': list(bet_cent.values())\n",
        "})\n",
        "\n",
        "print(\"Top Influential Users:\")\n",
        "print(centrality_df.sort_values(by='degree_centrality', ascending=False).head(10))\n",
        "\n",
        "# Community Detection\n",
        "from networkx.algorithms import community\n",
        "\n",
        "communities = community.greedy_modularity_communities(G)\n",
        "\n",
        "print(f\"Detected {len(communities)} communities\")\n",
        "\n",
        "# Visualize one community\n",
        "sample_comm = list(communities)[0]\n",
        "subG = G.subgraph(sample_comm)\n",
        "\n",
        "plt.figure(figsize=(8,8))\n",
        "pos = nx.spring_layout(subG, seed=42)\n",
        "nx.draw(subG, pos, node_size=50, with_labels=False)\n",
        "plt.title(\"Sample Community Graph\")\n",
        "plt.show()"
      ],
