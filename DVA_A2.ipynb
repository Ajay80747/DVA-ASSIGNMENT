      "source": [
        "import re\n",
        "from indicnlp.tokenize import indic_tokenize\n",
        "\n",
        "def clean_text(text):\n",
        "    # Lowercase\n",
        "    text = text.lower()\n",
        "    # Remove URLs\n",
        "    text = re.sub(r'http\\S+', '', text)\n",
        "    # Remove mentions\n",
        "    text = re.sub(r'@\\w+', '', text)\n",
        "    # Remove punctuations but keep indic characters\n",
        "    text = re.sub(r'[^\\w\\s\\#\\u0900-\\u0D7F]', '', text)\n",
        "    return text.strip()\n",
        "\n",
        "def tokenize_indic(text, lang='Hindi'):\n",
        "    # A simple wrapper for demo purposes. Indic NLP expects language codes (e.g., 'hi', 'mr', 'te')\n",
        "    # We fallback to basic split for non-supported or english.\n",
        "    lang_map = {'Hindi': 'hi', 'Marathi': 'mr', 'Telugu': 'te', 'Tamil': 'ta', 'Malayalam': 'ml', 'Punjabi': 'pa', 'Kannada': 'kn', 'Assamese': 'as'}\n",
        "    lang_code = lang_map.get(lang, 'en')\n",
        "\n",
        "    if lang_code == 'en':\n",
        "        return text.split()\n",
        "    try:\n",
        "        return indic_tokenize.trivial_tokenize(text)\n",
        "    except:\n",
        "        return text.split()\n",
        "\n",
        "df['cleaned_caption'] = df['caption'].apply(clean_text)\n",
        "df['tokens'] = df.apply(lambda row: tokenize_indic(row['cleaned_caption'], row['language']), axis=1)\n",
        "\n",
        "print(\"Before vs After Preprocessing (5 samples):\")\n",
        "display(df[['caption', 'cleaned_caption', 'tokens']].head(5))\n"
      ]
    },
