      "source": [
        "import networkx as nx\n",
        "\n",
        "# Create a sample graph of 500 users to render within notebook\n",
        "G = nx.Graph()\n",
        "\n",
        "import json\n",
        "with open(\"instagram_data.jsonl\", \"r\", encoding=\"utf-8\") as f:\n",
        "    for i, line in enumerate(f):\n",
        "        if i >= 500: break\n",
        "        d = json.loads(line)\n",
        "        user = d['user_profile']['username']\n",
        "        G.add_node(user)\n",
        "        for follower in d['network_data']['followers']:\n",
        "            G.add_edge(user, follower)\n",
        "\n",
        "print(f\"Graph created with {G.number_of_nodes()} nodes and {G.number_of_edges()} edges.\")\n",
        "\n",
        "plt.figure(figsize=(12, 12))\n",
        "# Draw a subset of nodes for clarity\n",
        "subG = G.subgraph(list(G.nodes())[:50])\n",
        "pos = nx.spring_layout(subG, seed=42)\n",
        "nx.draw(subG, pos, node_size=50, with_labels=False, alpha=0.6, edge_color='gray')\n",
        "plt.title(\"Sample Follower Network Graph\")\n",
        "plt.show()\n",
        "\n",
        "# Degree centrality\n",
        "degrees = [d for n, d in G.degree()]\n",
        "plt.figure(figsize=(10, 5))\n",
        "plt.hist(degrees, bins=30)\n",
        "plt.title(\"Degree Centrality Distribution\")\n",
        "plt.xlabel(\"Degree\")\n",
        "plt.ylabel(\"Frequency\")\n",
        "plt.show()\n"
      ]
    },
