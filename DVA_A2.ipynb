      "source": [
        "## 🔷 2. DATA EXTRACTION & 3. DATA SCHEMA\n",
        "\n",
        "> Add blockquote\n",
        "\n",
        "> Add blockquote\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "Simulating the dataset because of Instagram API restrictions. Here we generate structured JSON formatted data."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "code_65549162",
        "outputId": "459fd094-fe50-4dcb-cc65-a204477d2870"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Generated 500000 records successfully as JSON Lines.\n"
          ]
        }
      ],
      "source": [
        "import json\n",
        "import random\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "from datetime import datetime, timedelta\n",
        "\n",
        "# Updated for 500k scale (5 Lakh)\n",
        "NUM_SAMPLES = 500000\n",
        "LANGUAGES = ['English', 'Hindi', 'Marathi', 'Punjabi', 'Telugu', 'Kannada', 'Tamil', 'Assamese', 'Malayalam']\n",
        "\n",
        "sample_texts = {\n",
        "    'English': [\"Loving the new update!\", \"Check out this amazing view.\", \"Data Science is the future.\", \"Had a great time today.\", \"Can't wait for the weekend.\"],\n",
        "    'Hindi': [\"नई अपडेट बहुत अच्छी है!\", \"यह अद्भुत दृश्य देखें।\", \"डेटा विज्ञान भविष्य है।\", \"आज बहुत अच्छा समय बीता।\", \"सप्ताहांत का इंतजार नहीं कर सकता।\"],\n",
        "    'Marathi': [\"नवीन अपडेट खूप आवडले!\", \"हे अद्भुत दृश्य पहा.\", \"डेटा सायन्स भविष्य आहे.\", \"आज खूप छान वेळ घालवला.\", \"वीकेंडची वाट पाहू शकत नाही.\"],\n",
        "    'Telugu': [\"కొత్త అప్‌డేట్ చాలా బాగుంది!\", \"ఈ అద్భుత దృశ్యాన్ని చూడండి.\", \"డేటా సైన్స్ భవిష్యత్తు.\", \"ఈ రోజు చాలా ఆనందించాను.\", \"వీకెండ్ కోసం వేచి ఉండలేను.\"],\n",
        "    'Tamil': [\"புதிய அப்டேட் மிகவும் நன்றாக உள்ளது!\", \"இந்த அற்புதமான காட்சியை பாருங்கள்.\", \"டேட்டா சயின்ஸ் தான் எதிர்காலம்.\", \"இன்று மிகவும் நன்று.\", \"வார இறுதிக்காக காத்திருக்க முடியாது.\"]\n",
        "}\n",
        "\n",
        "for lang in LANGUAGES:\n",
        "    if lang not in sample_texts:\n",
        "        sample_texts[lang] = [f\"Sample text in {lang} 1\", f\"Sample text in {lang} 2\", f\"Sample text in {lang} 3\"]\n",
        "\n",
        "# Optimize memory for 500k scale by streaming to a JSON Lines file\n",
        "with open(\"instagram_data.jsonl\", \"w\", encoding='utf-8') as f:\n",
        "    for i in range(NUM_SAMPLES):\n",
        "        lang = random.choice(LANGUAGES)\n",
        "\n",
        "        record = {\n",
        "            \"user_profile\": {\n",
        "                \"username\": f\"user_{i}\",\n",
        "                \"bio\": f\"Bio of user {i}\",\n",
        "                \"profile_picture_url\": f\"http://example.com/pic_{i}.jpg\",\n",
        "                \"total_posts\": random.randint(10, 500)\n",
        "            },\n",
        "            \"content_data\": {\n",
        "                \"post_id\": f\"post_{i}\",\n",
        "                \"caption\": random.choice(sample_texts[lang]) + f\" #{lang} #trending\",\n",
        "                \"timestamp\": (datetime.now() - timedelta(days=random.randint(0,365))).isoformat()\n",
        "            },\n",
        "            \"interaction_data\": {\n",
        "                \"likes\": random.randint(0, 100000),\n",
        "                \"comments\": random.randint(0, 10000),\n",
        "                \"shares\": random.randint(0, 5000),\n",
        "                \"hashtags\": [lang.lower(), \"trending\", \"viral\"]\n",
        "            },\n",
        "            \"network_data\": {\n",
        "                \"followers\": [f\"user_{random.randint(0, NUM_SAMPLES-1)}\" for _ in range(random.randint(0, 5))],\n",
        "                \"following\": [f\"user_{random.randint(0, NUM_SAMPLES-1)}\" for _ in range(random.randint(0, 5))],\n",
        "                \"mutuals\": [],\n",
        "                \"communities\": [\"Data\", \"Lifestyle\"]\n",
        "            },\n",
        "            \"engagement_metrics\": {\n",
        "                \"likes_count\": random.randint(0, 10000),\n",
        "                \"comments_count\": random.randint(0, 1000),\n",
        "                \"share_count\": random.randint(0, 500),\n",
        "                \"view_count\": random.randint(100, 50000)\n",
        "            }\n",
        "        }\n",
        "\n",
        "        # Write directly to file as JSON Line\n",
        "        f.write(json.dumps(record, ensure_ascii=False) + \"\\n\")\n",
        "\n",
        "print(f\"Generated {NUM_SAMPLES} records successfully as JSON Lines.\")\n"
      ]
    },
