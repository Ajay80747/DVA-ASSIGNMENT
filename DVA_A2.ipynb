        "\n",
        "acc = accuracy_score(mock_ground_truth, mock_predictions)\n",
        "prec = precision_score(mock_ground_truth, mock_predictions, average='weighted', zero_division=0)\n",
        "rec = recall_score(mock_ground_truth, mock_predictions, average='weighted', zero_division=0)\n",
        "f1 = f1_score(mock_ground_truth, mock_predictions, average='weighted', zero_division=0)\n",
        "\n",
        "print(f\"Accuracy: {acc:.4f}\")\n",
        "print(f\"Precision: {prec:.4f}\")\n",
        "print(f\"Recall: {rec:.4f}\")\n",
        "print(f\"F1-Score: {f1:.4f}\")\n",
        "\n",
        "# BLEU score demo (useful for translation tasks in Multilingual BERT)\n",
        "refs = [[\"This is a sample reference string.\", \"Another refernce text.\"]]\n",
        "sys = [\"This is a generated sample string.\", \"Another reference text.\"]\n",
        "bleu = sacrebleu.corpus_bleu(sys, refs)\n",
        "print(f\"BLEU Score: {bleu.score:.2f}\")\n",
        "\n",
        "def calculate_cer_wer(reference, hypothesis):\n",
        "    try:\n",
        "        from jiwer import wer, cer\n",
        "        return wer(reference, hypothesis), cer(reference, hypothesis)\n",
        "    except ImportError:\n",
        "        return \"Install jiwer\", \"Install jiwer\"\n",
        "\n",
        "w, c = calculate_cer_wer(\"This is a reference\", \"This is generated\")\n",
        "print(f\"WER: {w}, CER: {c}\")\n"
