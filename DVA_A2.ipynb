      "source": [
        "import seaborn as sns\n",
        "import plotly.express as px\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# Basic: Bar Chart for Language Distribution\n",
        "plt.figure(figsize=(10, 5))\n",
        "sns.countplot(data=df, x='language', order=df['language'].value_counts().index)\n",
        "plt.title(\"Language Distribution\")\n",
        "plt.xticks(rotation=45)\n",
        "plt.show()\n",
        "\n",
        "# Basic: Histogram for Engagement\n",
        "plt.figure(figsize=(10, 5))\n",
        "sns.histplot(df['likes'], bins=50, kde=True)\n",
        "plt.title(\"Likes Distribution (Engagement Metric)\")\n",
        "plt.show()\n",
        "\n",
        "# Advanced: Heatmap\n",
        "plt.figure(figsize=(8, 6))\n",
        "correlation = df[['likes', 'comments', 'shares', 'followers']].corr()\n",
        "sns.heatmap(correlation, annot=True, cmap='coolwarm', fmt=\".2f\")\n",
        "plt.title(\"Engagement Correlation Heatmap\")\n",
        "plt.show()\n",
        "\n",
        "# Interactive: Plotly Scatter\n",
        "fig = px.scatter(df.head(1000), x='likes', y='comments', color='language', hover_data=['username'],\n",
        "                 title='Likes vs Comments by Language (Interactive)')\n",
        "fig.show()\n"
      ]
    },
