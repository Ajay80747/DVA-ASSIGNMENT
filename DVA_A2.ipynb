      "source": [
        "import pandas as pd\n",
        "import json\n",
        "\n",
        "# Flatten and read line-by-line to prevent out-of-memory errors\n",
        "df_list = []\n",
        "with open(\"instagram_data.jsonl\", \"r\", encoding=\"utf-8\") as f:\n",
        "    for line in f:\n",
        "        d = json.loads(line)\n",
        "        # Adding a language tag dynamically for demonstration based on hashtag\n",
        "        lang = d['interaction_data']['hashtags'][0].capitalize()\n",
        "        flat = {\n",
        "            'username': d['user_profile']['username'],\n",
        "            'caption': d['content_data']['caption'],\n",
        "            'language': lang,\n",
        "            'timestamp': d['content_data']['timestamp'],\n",
        "            'likes': d['interaction_data']['likes'],\n",
        "            'comments': d['interaction_data']['comments'],\n",
        "            'shares': d['interaction_data']['shares'],\n",
        "            'hashtags': \" \".join(d['interaction_data']['hashtags']),\n",
        "            'followers': len(d['network_data']['followers'])\n",
        "        }\n",
        "        df_list.append(flat)\n",
        "\n",
        "df = pd.DataFrame(df_list)\n",
        "print(\"Dataset Shape:\", df.shape)\n",
        "print(\"\\nColumn Names:\", df.columns.tolist())\n",
        "display(df.head(5))\n"
      ]
    },
